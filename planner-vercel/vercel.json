{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/public/index.html" }
  ],
  "functions": {
    "api/analyze.js": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/data/(.*)",
      "headers": [
        { "key": "Content-Type", "value": "text/csv; charset=utf-8" }
      ]
    }
  ]
}
